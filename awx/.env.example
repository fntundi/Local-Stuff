# =============================================================================
# AWX Environment — copy to .env and fill in values
# Generate secrets with: openssl rand -base64 48
# =============================================================================

# AWX version
AWX_VERSION=24.6.0

# Web port (default 8052, use 80 if behind Traefik)
AWX_HOST_PORT=8052

# Admin credentials
AWX_ADMIN_USER=admin
AWX_ADMIN_PASSWORD=change_me_now

# Secret key (must be stable — changing it invalidates stored credentials)
AWX_SECRET_KEY=

# PostgreSQL
AWX_PG_DATABASE=awx
AWX_PG_USERNAME=awx
AWX_PG_PASSWORD=

# Redis
AWX_REDIS_PASSWORD=
