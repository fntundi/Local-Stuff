# local-aistack — managed by Ansible
# Generated: {{ ansible_date_time.iso8601 }}
# Source: awx/roles/local_aistack/templates/local_aistack.env.j2

# Core
ENV={{ platform_env }}
BIND_ADDRESS={{ aistack_bind_address }}
CLOUDFLARE_TUNNEL_TOKEN={{ cloudflare_tunnel_token }}

# PostgreSQL
POSTGRES_DB=aistack
POSTGRES_USER=postgres
POSTGRES_PASSWORD={{ aistack_postgres_password }}
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://postgres:{{ aistack_postgres_password }}@postgres:5432/aistack
MLFLOW_BACKEND_STORE_URI=postgresql://postgres:{{ aistack_postgres_password }}@postgres:5432/mlflow

# Qdrant
QDRANT_API_KEY={{ aistack_qdrant_api_key }}
QDRANT_LOG_LEVEL=INFO
QDRANT_URL=http://qdrant:6333

# Ollama
OLLAMA_BASE_URL=http://ollama-chat:11434
OLLAMA_API_KEY=ollama
OLLAMA_KEEP_ALIVE={{ aistack_ollama_keep_alive }}
DEFAULT_CHAT_MODEL={{ aistack_ollama_chat_model }}
DEFAULT_CODE_MODEL={{ aistack_ollama_code_model }}
DEFAULT_EMBEDDING_MODEL={{ aistack_ollama_embedding_model }}

# Activepieces
AP_ENVIRONMENT=production
AP_FRONTEND_URL=http://localhost:{{ port_aistack_openwebui }}
AP_DB_TYPE=postgres
AP_POSTGRES_DATABASE=activepieces
AP_POSTGRES_USERNAME=postgres
AP_POSTGRES_PASSWORD={{ aistack_postgres_password }}
AP_POSTGRES_HOST=postgres
AP_POSTGRES_PORT=5432
AP_REDIS_URL=redis://:{{ aistack_ap_jwt_secret }}@redis:6379
AP_ENCRYPTION_KEY={{ aistack_ap_encryption_key }}
AP_JWT_SECRET={{ aistack_ap_jwt_secret }}
AP_TELEMETRY_ENABLED=false
AP_RETENTION_DAYS=30

# OpenWebUI
OPENWEBUI_SECRET_KEY={{ aistack_openwebui_secret_key }}
OPENWEBUI_AUTH=true
ENABLE_SIGNUP=true

# JupyterLab
JUPYTER_TOKEN={{ aistack_jupyter_token }}

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD={{ aistack_minio_root_password }}
MINIO_DEFAULT_BUCKETS={{ aistack_minio_bucket_mlflow }},{{ aistack_minio_bucket_ci }}
PORTAINER_ADMIN_PASSWORD={{ aistack_portainer_password }}

# MLflow
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_DEFAULT_ARTIFACT_ROOT=s3://{{ aistack_minio_bucket_mlflow }}
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY={{ aistack_minio_root_password }}
MLFLOW_S3_ENDPOINT_URL=http://minio:9000

# LiteLLM
LITELLM_MASTER_KEY={{ aistack_litellm_master_key }}
LITELLM_DATABASE_URL=postgresql://postgres:{{ aistack_postgres_password }}@postgres:5432/litellm
LITELLM_BASE_URL=http://litellm:4000
LITELLM_DOMAIN=litellm.{{ domain_local }}

# Langfuse
LANGFUSE_PUBLIC_KEY={{ aistack_langfuse_public_key }}
LANGFUSE_SECRET_KEY={{ aistack_langfuse_secret_key }}
LANGFUSE_DATABASE_URL=postgresql://postgres:{{ aistack_postgres_password }}@postgres:5432/langfuse
LANGFUSE_NEXTAUTH_SECRET={{ aistack_langfuse_nextauth_secret }}
LANGFUSE_SALT={{ aistack_langfuse_salt }}
LANGFUSE_ENCRYPTION_KEY={{ aistack_langfuse_enc_key }}

# OpenSearch
OPENSEARCH_HOST=opensearch
OPENSEARCH_DOMAIN=opensearch.{{ domain_local }}

# API Server
API_AUTH_USERNAME={{ aistack_api_auth_username }}
API_AUTH_PASSWORD={{ aistack_api_auth_password }}
API_JWT_SECRET={{ aistack_api_jwt_secret }}
API_JWT_ALGORITHM=HS256
API_SERVER_DOMAIN=aistack.{{ domain_local }}

# RAG defaults
DEFAULT_TOP_K=5
DEFAULT_CHUNK_SIZE=512

# Network
NETWORK_NAME={{ aistack_network }}
