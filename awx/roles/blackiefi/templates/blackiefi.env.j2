# BlackieFi environment — managed by Ansible
# Generated: {{ ansible_date_time.iso8601 }}

APP_SCHEME=https
APP_HOSTNAME={{ blackiefi_hostname }}
APP_BASE_URL=https://{{ blackiefi_hostname }}
CORS_ORIGIN=https://{{ blackiefi_hostname }}

CLUSTER_NAME={{ blackiefi_k3d_cluster }}
REGISTRY_PORT={{ blackiefi_registry_port }}
NAMESPACE={{ blackiefi_namespace }}
K3D_SERVERS=1
K3D_AGENTS=1
HTTP_PORT={{ port_http }}
HTTPS_PORT={{ port_https }}

POSTGRES_PASSWORD={{ blackiefi_postgres_password }}
AUTOMATION_SHARED_KEY={{ blackiefi_automation_key }}

BOOTSTRAP_USERNAME=admin
BOOTSTRAP_EMAIL=admin@{{ domain_public }}
BOOTSTRAP_NAME=Admin
BOOTSTRAP_PASSWORD={{ blackiefi_bootstrap_password }}
BOOTSTRAP_ROLE=admin
SESSION_TTL_HOURS=720

AI_MODE=false
LLM_PROVIDER_TYPE=disabled
