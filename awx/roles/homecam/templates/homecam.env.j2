# HomeCam environment — managed by Ansible
# Generated: {{ ansible_date_time.iso8601 }}

# MongoDB
MONGO_INITDB_ROOT_USERNAME={{ homecam_mongo_user }}
MONGO_INITDB_ROOT_PASSWORD={{ homecam_mongo_password }}
MONGO_DB=sentinel_noc

# Backend
JWT_SECRET={{ homecam_jwt_secret }}
ENCRYPTION_KEY={{ homecam_encryption_key }}
GIN_MODE={{ 'release' if platform_env == 'prod' else 'debug' }}

# Frontend
REACT_APP_API_URL=/api
NODE_ENV={{ platform_env }}

# MediaMTX
MEDIAMTX_RTSP_PORT={{ port_rtsp }}
MEDIAMTX_HLS_PORT={{ port_homecam_hls }}
