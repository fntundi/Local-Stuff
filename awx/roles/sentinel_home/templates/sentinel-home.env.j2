# Sentinel-Home environment — managed by Ansible
# Generated: {{ ansible_date_time.iso8601 }}

APP_NAME=sentinel-home
APP_DISPLAY_NAME=Sentinel-Home
APP_HOSTNAME={{ sentinel_hostname }}
APP_BASE_URL={{ sentinel_base_url }}
ENVIRONMENT={{ platform_env }}

# Authentik SSO
AUTHENTIK_ISSUER=https://authentik.blackiechan.net
AUTHENTIK_CLIENT_ID={{ sentinel_authentik_client_id }}
AUTHENTIK_REDIRECT_URL={{ sentinel_authentik_redirect_url }}

# Database
MONGO_USERNAME=admin
MONGO_PASSWORD={{ sentinel_mongo_password }}
MONGO_DB_NAME=sentinel_home

# Application secrets
JWT_SECRET={{ sentinel_jwt_secret }}
ENCRYPTION_KEY={{ sentinel_encryption_key }}

# k3d NodePorts (informational)
K3D_FRONTEND_PORT={{ sentinel_k3d_lb_http_port }}
K3D_BACKEND_PORT={{ sentinel_k3d_backend_port }}
