// ============================================================================
// local-aistack — Backend CI Pipeline
// Python 3.11 · FastAPI · api-server, code-executor, workflows-runner, general-mcp
//
// Artifacts → MinIO: {MINIO_BUCKET}/local-aistack/backend/{BUILD_DATE}/{BUILD_NUMBER}/{type}/
// ============================================================================

@Library('home-platform') _

def loadEnvFiles() {
    ['jenkins/pipelines/global.env', 'jenkins/pipelines/local-aistack/local-aistack.env'].each { f ->
        if (fileExists(f)) {
            readFile(f).readLines().each { line ->
                if (line && !line.startsWith('#') && line.contains('=')) {
                    def parts = line.split('=', 2)
                    if (parts.length == 2) env[parts[0].trim()] = parts[1].trim()
                }
            }
        }
    }
}

pipeline {

    agent none

    options {
        ansiColor('xterm')
        timestamps()
        timeout(time: 60, unit: 'MINUTES')
        buildDiscarder(logRotator(numToKeepStr: '50', daysToKeepStr: '30'))
        disableConcurrentBuilds()
    }

    parameters {
        choice(name: 'ENVIRONMENT', choices: ['dev','staging','prod'], description: 'Target environment')
        booleanParam(name: 'SKIP_SONAR',  defaultValue: false, description: 'Skip SonarQube')
        booleanParam(name: 'SKIP_ZAP',    defaultValue: false, description: 'Skip ZAP DAST')
        booleanParam(name: 'SKIP_DEPLOY', defaultValue: true,  description: 'Skip image push')
        string(name: 'DOCKER_TAG', defaultValue: '', description: 'Override image tag')
    }

    environment {
        APP          = 'local-aistack'
        COMPONENT    = 'backend'
        PYTHON_IMAGE = 'python:3.11-slim'
        SRC_DIR      = 'local-aistack/src'
        COMPOSE_FILE = 'local-aistack/compose/docker-compose.yml'
        SONAR_TOKEN  = credentials('sonarqube-token')
        DOCKER_CREDS = credentials('docker-registry-creds')
        MINIO_CREDS  = credentials('minio-credentials')
        ARTIFACT_DIR = 'build-artifacts'
    }

    stages {

        stage('Checkout') {
            agent { label 'docker' }
            steps {
                checkout scm
                sh 'git submodule update --init --recursive'
                script {
                    loadEnvFiles()
                    env.GIT_SHORT = sh(returnStdout: true, script: 'git rev-parse --short HEAD').trim()
                    env.IMAGE_TAG = params.DOCKER_TAG ?: env.GIT_SHORT
                    env.BUILD_DATE          = sh(returnStdout: true, script: 'date +%Y-%m-%d').trim()
                    env.MINIO_REMOTE_PATH   = "local-aistack/backend/${env.BUILD_DATE}/${env.BUILD_NUMBER}"
                    env.MINIO_ENDPOINT_RESOLVED = env.MINIO_ENDPOINT ?: 'http://minio:9000'
                    env.MINIO_BUCKET_RESOLVED   = env.MINIO_BUCKET   ?: 'ci-artifacts'
                    sh "mkdir -p ${env.ARTIFACT_DIR}/{unit,smoke,functional,regression,zap,sonar,lint}"
                    echo "MinIO path: ${env.MINIO_BUCKET_RESOLVED}/${env.MINIO_REMOTE_PATH}"
                }
            }
        }

        stage('Lint') {
            parallel {
                stage('flake8') {
                    agent { docker { image env.PYTHON_IMAGE; reuseNode true } }
                    steps {
                        sh """
                            pip install flake8 flake8-bugbear --quiet
                            flake8 ${env.SRC_DIR}/ --max-line-length=120 \\
                                --exclude=__pycache__,.git \\
                                2>&1 | tee ${env.ARTIFACT_DIR}/lint/flake8.txt || true
                        """
                    }
                }
                stage('black') {
                    agent { docker { image env.PYTHON_IMAGE; reuseNode true } }
                    steps {
                        sh """
                            pip install black --quiet
                            black --check --diff ${env.SRC_DIR}/ \\
                                2>&1 | tee ${env.ARTIFACT_DIR}/lint/black.txt || true
                        """
                    }
                }
                stage('mypy') {
                    agent { docker { image env.PYTHON_IMAGE; reuseNode true } }
                    steps {
                        sh """
                            pip install mypy --quiet
                            mypy ${env.SRC_DIR}/ --ignore-missing-imports \\
                                2>&1 | tee ${env.ARTIFACT_DIR}/lint/mypy.txt || true
                        """
                    }
                }
            }
            post {
                always { archiveArtifacts artifacts: "${env.ARTIFACT_DIR}/lint/**", allowEmptyArchive: true }
            }
        }

        stage('Build Images') {
            agent { label 'docker' }
            steps {
                sh """
                    echo \${DOCKER_CREDS_PSW} | docker login ${env.DOCKER_REGISTRY} -u \${DOCKER_CREDS_USR} --password-stdin || true
                    for svc in api-server code-executor workflows-runner general-mcp; do
                        IMG_PATH="compose/docker/\${svc}"
                        if [ -d "\${IMG_PATH}" ]; then
                            docker build \\
                                --cache-from ${env.DOCKER_REGISTRY}/aistack-\${svc}:latest \\
                                --tag ${env.DOCKER_REGISTRY}/aistack-\${svc}:${env.IMAGE_TAG} \\
                                --tag ${env.DOCKER_REGISTRY}/aistack-\${svc}:latest \\
                                \${IMG_PATH}
                        fi
                    done
                """
            }
        }

        stage('Unit Tests') {
            agent { docker { image env.PYTHON_IMAGE; reuseNode true } }
            steps {
                sh """
                    pip install -r requirements.txt --quiet
                    pip install pytest pytest-cov pytest-asyncio httpx --quiet
                    pytest ${env.SRC_DIR}/ -v \\
                        -m "unit or not (functional or regression or smoke or integration)" \\
                        --tb=short \\
                        --cov=${env.SRC_DIR}/ \\
                        --cov-report=xml:${env.ARTIFACT_DIR}/unit/coverage.xml \\
                        --cov-report=term-missing \\
                        --junitxml=${env.ARTIFACT_DIR}/unit/results.xml \\
                        2>&1 | tee ${env.ARTIFACT_DIR}/unit/output.txt || true
                """
            }
            post {
                always {
                    junit allowEmptyResults: true, testResults: "${env.ARTIFACT_DIR}/unit/results.xml"
                    archiveArtifacts artifacts: "${env.ARTIFACT_DIR}/unit/**", allowEmptyArchive: true
                }
            }
        }

        stage('Integration Tests') {
            agent { label 'docker' }
            stages {

                stage('Start Core Services') {
                    steps {
                        sh """
                            mkdir -p ${env.ARTIFACT_DIR}/{smoke,functional,regression}
                            docker compose \\
                                --project-name aistack-test-${env.BUILD_NUMBER} \\
                                --file ${env.COMPOSE_FILE} \\
                                up -d --wait postgres redis api-server
                        """
                        sh 'sleep 8'
                    }
                }

                stage('Smoke Tests') {
                    steps {
                        sh """
                            SMOKE_STATUS=FAIL
                            curl -sf http://localhost:8000/health > /dev/null && SMOKE_STATUS=PASS
                            echo "SMOKE_STATUS=\${SMOKE_STATUS}"        | tee ${env.ARTIFACT_DIR}/smoke/results.txt
                            echo "API_URL=http://localhost:8000/health" >> ${env.ARTIFACT_DIR}/smoke/results.txt
                            [ "\${SMOKE_STATUS}" = "PASS" ]
                        """
                    }
                }

                stage('Functional Tests') {
                    agent { docker { image env.PYTHON_IMAGE; args '--network host'; reuseNode true } }
                    steps {
                        sh """
                            pip install -r requirements.txt pytest pytest-asyncio httpx --quiet
                            pytest ${env.SRC_DIR}/ -v -m functional --tb=short \\
                                --junitxml=${env.ARTIFACT_DIR}/functional/results.xml \\
                                2>&1 | tee ${env.ARTIFACT_DIR}/functional/output.txt || true
                        """
                    }
                    post {
                        always { junit allowEmptyResults: true, testResults: "${env.ARTIFACT_DIR}/functional/results.xml" }
                    }
                }

                stage('Regression Tests') {
                    agent { docker { image env.PYTHON_IMAGE; args '--network host'; reuseNode true } }
                    steps {
                        sh """
                            pip install -r requirements.txt pytest pytest-asyncio httpx --quiet
                            pytest ${env.SRC_DIR}/ -v -m regression --tb=short \\
                                --junitxml=${env.ARTIFACT_DIR}/regression/results.xml \\
                                2>&1 | tee ${env.ARTIFACT_DIR}/regression/output.txt || true
                        """
                    }
                    post {
                        always { junit allowEmptyResults: true, testResults: "${env.ARTIFACT_DIR}/regression/results.xml" }
                    }
                }

                stage('Tear Down') {
                    steps {
                        sh "docker compose --project-name aistack-test-${env.BUILD_NUMBER} down --volumes --remove-orphans || true"
                    }
                }

            }
            post {
                always {
                    stash name: "aistack-be-int-${env.BUILD_NUMBER}",
                          includes: "${env.ARTIFACT_DIR}/**",
                          allowEmpty: true
                }
            }
        }

        stage('SonarQube') {
            when { not { expression { params.SKIP_SONAR } } }
            agent { label 'docker' }
            steps {
                sh "mkdir -p ${env.ARTIFACT_DIR}/sonar"
                sonarScan(
                    projectKey:     env.SONAR_PROJECT_KEY_BACKEND ?: 'home-platform.aistack.backend',
                    projectName:    'local-aistack Backend',
                    sources:        env.SRC_DIR,
                    language:       'python',
                    coverageReport: "${env.ARTIFACT_DIR}/unit/coverage.xml",
                    exclusions:     '**/__pycache__/**,**/notebooks/**,**/migrations/**',
                    artifactDir:    env.ARTIFACT_DIR,
                )
            }
            post {
                always {
                    stash name: "aistack-be-sonar-${env.BUILD_NUMBER}",
                          includes: "${env.ARTIFACT_DIR}/sonar/**",
                          allowEmpty: true
                }
            }
        }

        stage('ZAP Scan') {
            when { not { expression { params.SKIP_ZAP } } }
            agent { label 'docker' }
            steps {
                sh """
                    mkdir -p ${env.ARTIFACT_DIR}/zap
                    docker compose --project-name aistack-zap-${env.BUILD_NUMBER} \\
                        --file ${env.COMPOSE_FILE} up -d --wait postgres redis api-server
                """
                script {
                    try {
                        zapScan(
                            target:      'http://localhost:8000',
                            mode:        env.ZAP_SCAN_MODE ?: 'baseline',
                            reportName:  'aistack-backend',
                            network:     'host',
                            artifactDir: env.ARTIFACT_DIR,
                        )
                    } finally {
                        sh "docker compose --project-name aistack-zap-${env.BUILD_NUMBER} down --volumes || true"
                    }
                }
            }
            post {
                always {
                    stash name: "aistack-be-zap-${env.BUILD_NUMBER}",
                          includes: "${env.ARTIFACT_DIR}/zap/**",
                          allowEmpty: true
                }
            }
        }

        stage('Push Images') {
            when { not { expression { params.SKIP_DEPLOY } } }
            agent { label 'docker' }
            steps {
                sh """
                    echo \${DOCKER_CREDS_PSW} | docker login ${env.DOCKER_REGISTRY} -u \${DOCKER_CREDS_USR} --password-stdin
                    for svc in api-server code-executor workflows-runner general-mcp; do
                        docker push ${env.DOCKER_REGISTRY}/aistack-\${svc}:${env.IMAGE_TAG} || true
                        docker push ${env.DOCKER_REGISTRY}/aistack-\${svc}:latest || true
                    done
                """
            }
        }

    } // end stages

    post {
        always {
            node('docker') {
                checkout scm
                sh "mkdir -p ${env.ARTIFACT_DIR}/{unit,smoke,functional,regression,zap,sonar,lint}"
                script {
                    ["aistack-be-int-${env.BUILD_NUMBER}",
                     "aistack-be-sonar-${env.BUILD_NUMBER}",
                     "aistack-be-zap-${env.BUILD_NUMBER}"].each { s ->
                        try { unstash s } catch (e) { echo "Stash ${s} not available" }
                    }
                }
                buildSummary(
                    app: 'local-aistack', component: 'backend',
                    buildNumber: env.BUILD_NUMBER, buildResult: currentBuild.currentResult,
                    buildUrl: env.BUILD_URL, artifactDir: env.ARTIFACT_DIR,
                    minioEndpoint: env.MINIO_ENDPOINT_RESOLVED ?: 'http://minio:9000',
                    minioBucket:   env.MINIO_BUCKET_RESOLVED   ?: 'ci-artifacts',
                    minioPath:     env.MINIO_REMOTE_PATH ?: "local-aistack/backend/unknown/${env.BUILD_NUMBER}",
                )
                publishToMinio(
                    app: 'local-aistack', component: 'backend',
                    buildDate: env.BUILD_DATE ?: sh(returnStdout: true, script: 'date +%Y-%m-%d').trim(),
                    buildNumber: env.BUILD_NUMBER,
                    endpoint: env.MINIO_ENDPOINT_RESOLVED ?: 'http://minio:9000',
                    bucket:   env.MINIO_BUCKET_RESOLVED   ?: 'ci-artifacts',
                    localDir: env.ARTIFACT_DIR, credentialsId: 'minio-credentials',
                )
                cleanWs()
            }
        }
        success { echo "local-aistack backend CI passed" }
        failure { echo "local-aistack backend CI FAILED" }
    }

}
