# local-aistack — application-level environment variables
APP_NAME=local-aistack
APP_DISPLAY_NAME=local-aistack (AI Platform)

BACKEND_DIR=local-aistack/src
COMPOSE_DIR=local-aistack/compose
K8S_DIR=local-aistack/k8s/base
K8S_NAMESPACE=ai-platform

API_SERVER_IMAGE=${DOCKER_REGISTRY}/aistack-api-server
CODE_EXECUTOR_IMAGE=${DOCKER_REGISTRY}/aistack-code-executor
WORKFLOWS_RUNNER_IMAGE=${DOCKER_REGISTRY}/aistack-workflows-runner
GENERAL_MCP_IMAGE=${DOCKER_REGISTRY}/aistack-general-mcp

API_URL_DEV=http://api-server:8000
API_URL_PROD=https://api.blackiechan.net

OPENWEBUI_URL_DEV=http://openwebui:3000
JUPYTERLAB_URL_DEV=http://jupyterlab:8888
MLFLOW_URL_DEV=http://mlflow:5000
MINIO_CONSOLE_URL_DEV=http://minio:9001
LITELLM_URL_DEV=http://litellm:4000

PYTHON_VERSION=3.11
PYTEST_ARGS=--tb=short -q
COVERAGE_REPORT=coverage.xml
LINT_DIRS=local-aistack/src/

SONAR_PROJECT_KEY_BACKEND=home-platform.aistack.backend

ZAP_TARGET_BACKEND=${API_URL_DEV}
ZAP_TARGET_OPENWEBUI=${OPENWEBUI_URL_DEV}
ZAP_TARGET_JUPYTERLAB=${JUPYTERLAB_URL_DEV}

COMPOSE_FILE=local-aistack/compose/docker-compose.yml
COMPOSE_PROD_FILE=local-aistack/compose/docker-compose.prod.yml
ENV_FILE_DEV=local-aistack/env/.env.dev
ENV_FILE_PROD=local-aistack/env/.env.prod

KUBECONFIG_CRED_ID=kubeconfig-aistack
