# Sentinel-Home — application-level environment variables
APP_NAME=sentinel-home
APP_DISPLAY_NAME=Sentinel-Home

BACKEND_DIR=sentinel-home/backend
FRONTEND_DIR=sentinel-home/frontend
K8S_DIR=sentinel-home/k8s
K8S_NAMESPACE=sentinel-home
K3D_CLUSTER=sentinel-home
K3D_CONFIG=sentinel-home/k8s/k3d-config.yaml

BACKEND_IMAGE=${DOCKER_REGISTRY}/sentinel-home-backend
FRONTEND_IMAGE=${DOCKER_REGISTRY}/sentinel-home-frontend

# k3d NodePorts (host-facing, Traefik routes to these)
K3D_FRONTEND_PORT=31000
K3D_BACKEND_PORT=31001

BACKEND_URL_DEV=http://localhost:31001
FRONTEND_URL_DEV=http://localhost:31000
FRONTEND_URL_PROD=https://sentinel.blackiechan.net

BACKEND_LANG=python

SONAR_PROJECT_KEY_BACKEND=home-platform.sentinel-home.backend
SONAR_PROJECT_KEY_FRONTEND=home-platform.sentinel-home.frontend

ZAP_TARGET_BACKEND=${BACKEND_URL_DEV}
ZAP_TARGET_FRONTEND=${FRONTEND_URL_DEV}

KUBECONFIG_CRED_ID=kubeconfig-sentinel
