# HomeCam — application-level environment variables
APP_NAME=homecam
APP_DISPLAY_NAME=HomeCam (Sentinel NOC)

BACKEND_DIR=homecam/backend
FRONTEND_DIR=homecam/frontend
K8S_DIR=homecam/k8s
K8S_NAMESPACE=sentinel-noc

BACKEND_IMAGE=${DOCKER_REGISTRY}/homecam-backend
FRONTEND_IMAGE=${DOCKER_REGISTRY}/homecam-frontend

BACKEND_URL_DEV=http://homecam-backend:8001
BACKEND_URL_STAGING=http://homecam-backend-staging:8001
BACKEND_URL_PROD=https://homecam.blackiechan.net/api

FRONTEND_URL_DEV=http://homecam-frontend:3000
FRONTEND_URL_STAGING=http://homecam-frontend-staging:3000
FRONTEND_URL_PROD=https://homecam.blackiechan.net

GO_VERSION=1.21
CGO_ENABLED=0
GOFLAGS=-mod=mod
COVERAGE_REPORT=coverage.out

NODE_VERSION=20
CI=true
GENERATE_SOURCEMAP=false

SONAR_PROJECT_KEY_BACKEND=home-platform.homecam.backend
SONAR_PROJECT_KEY_FRONTEND=home-platform.homecam.frontend

ZAP_TARGET_BACKEND=${BACKEND_URL_DEV}
ZAP_TARGET_FRONTEND=${FRONTEND_URL_DEV}

KUBECONFIG_CRED_ID=kubeconfig-homecam
K3D_CLUSTER_NAME=sentinel-noc
