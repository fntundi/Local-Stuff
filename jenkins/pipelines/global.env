# =============================================================================
# Global environment variables — loaded by every pipeline before app-level env
# Override any value at the Jenkins job level or via pipeline parameters.
# =============================================================================

# ---------------------------------------------------------------------------
# MinIO artifact storage
# Artifact path convention:
#   {MINIO_BUCKET}/{APP}/{COMPONENT}/{BUILD_DATE}/{BUILD_NUMBER}/{artifact_type}/
#
# Required Jenkins credential: minio-credentials  (username=access_key, password=secret_key)
# ---------------------------------------------------------------------------
MINIO_ENDPOINT=${JENKINS_MINIO_ENDPOINT}
MINIO_BUCKET=${JENKINS_MINIO_BUCKET}

# ---------------------------------------------------------------------------
# Container registry
# ---------------------------------------------------------------------------
DOCKER_REGISTRY=${JENKINS_DOCKER_REGISTRY}
DOCKER_REGISTRY_NAMESPACE=home-platform

# ---------------------------------------------------------------------------
# SonarQube
# Required Jenkins credential: sonarqube-token
# ---------------------------------------------------------------------------
SONARQUBE_URL=${JENKINS_SONARQUBE_URL}
SONARQUBE_PROJECT_KEY_PREFIX=home-platform

# ---------------------------------------------------------------------------
# OWASP ZAP
# ---------------------------------------------------------------------------
ZAP_IMAGE=ghcr.io/zaproxy/zaproxy:stable
ZAP_SCAN_MODE=baseline          # baseline | full
ZAP_FAIL_ON_WARN=false

# ---------------------------------------------------------------------------
# Playwright / Section 508
# ---------------------------------------------------------------------------
PLAYWRIGHT_IMAGE=mcr.microsoft.com/playwright:v1.44.0-jammy
WCAG_LEVEL=wcag21aa
PLAYWRIGHT_BROWSERS=chromium

# ---------------------------------------------------------------------------
# Networking — shared Traefik gateway network
# ---------------------------------------------------------------------------
TRAEFIK_NETWORK=${JENKINS_TRAEFIK_NETWORK}

# ---------------------------------------------------------------------------
# Build settings
# ---------------------------------------------------------------------------
DOCKER_BUILDKIT=1
BUILD_CACHE_DIR=/tmp/buildcache

# ---------------------------------------------------------------------------
# Notification
# ---------------------------------------------------------------------------
SLACK_CHANNEL=#ci-alerts
NOTIFY_ON_FAILURE=true
NOTIFY_ON_RECOVERY=true
