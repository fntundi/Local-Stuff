# Authentik stack environment
# NOTE: 'make preflight' auto-generates all secrets into the root .env.
#       Docker Compose reads the root .env automatically when run from the
#       repo root — a separate authentik/.env is not required.
#       This file documents the required variables.

AUTHENTIK_VERSION=2026.2
AUTHENTIK_SECRET_KEY=        # generate: openssl rand -hex 32
AUTHENTIK_PG_PASSWORD=       # generate: openssl rand -hex 16

# Bootstrap — sets akadmin password and creates an API token on first start.
# AUTHENTIK_BOOTSTRAP_TOKEN is used by 'make authentik-setup' to provision
# the blackie-chan platform admin user via the Authentik API.
AUTHENTIK_BOOTSTRAP_PASSWORD=   # generate: openssl rand -base64 18 | tr -d '/+='
AUTHENTIK_BOOTSTRAP_TOKEN=      # generate: openssl rand -hex 20

AUTHENTIK_ERROR_REPORTING__ENABLED=false
TZ=America/New_York
