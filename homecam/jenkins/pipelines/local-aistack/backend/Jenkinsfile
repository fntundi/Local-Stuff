// ============================================================================
// local-aistack — Backend CI Pipeline
// Python 3.11 | FastAPI / API server, code-executor, workflows-runner, general-mcp
//
// Stages:
//   Checkout → Lint (flake8+black+mypy) → Build Images → Unit Tests →
//   Smoke → Functional → Regression → SonarQube → ZAP
// ============================================================================

@Library('home-platform') _

pipeline {

    agent none

    options {
        ansiColor('xterm')
        timestamps()
        timeout(time: 60, unit: 'MINUTES')
        buildDiscarder(logRotator(numToKeepStr: '50', daysToKeepStr: '30'))
        disableConcurrentBuilds()
    }

    parameters {
        choice(
            name: 'ENVIRONMENT',
            choices: ['dev', 'staging', 'prod'],
            description: 'Target environment'
        )
        booleanParam(name: 'SKIP_SONAR',  defaultValue: false, description: 'Skip SonarQube')
        booleanParam(name: 'SKIP_ZAP',    defaultValue: false, description: 'Skip ZAP DAST')
        booleanParam(name: 'SKIP_DEPLOY', defaultValue: true,  description: 'Skip image push')
        string(name: 'DOCKER_TAG', defaultValue: '', description: 'Override image tag')
    )

    environment {
        APP           = 'local-aistack'
        COMPONENT     = 'backend'
        PYTHON_IMAGE  = 'python:3.11-slim'
        SRC_DIR       = 'src'
        COMPOSE_FILE  = 'compose/docker-compose.yml'
        SONAR_KEY     = 'home-platform.aistack.backend'
        SONAR_TOKEN   = credentials('sonarqube-token')
        DOCKER_CREDS  = credentials('docker-registry-creds')
    }

    stages {

        stage('Checkout') {
            agent { label 'docker' }
            steps {
                checkout scm
                script {
                    env.GIT_SHORT = sh(returnStdout: true, script: 'git rev-parse --short HEAD').trim()
                    env.IMAGE_TAG = params.DOCKER_TAG ?: env.GIT_SHORT

                    def globalEnv = readFile('jenkins/pipelines/global.env')
                    def appEnv    = readFile('jenkins/pipelines/local-aistack/local-aistack.env')
                    [globalEnv, appEnv].each { block ->
                        block.readLines().each { line ->
                            if (line && !line.startsWith('#') && line.contains('=')) {
                                def (k, v) = line.split('=', 2)
                                env[k.trim()] = v.trim()
                            }
                        }
                    }
                }
            }
        }

        stage('Lint') {
            parallel {

                stage('flake8') {
                    agent {
                        docker { image env.PYTHON_IMAGE; reuseNode true }
                    }
                    steps {
                        sh """
                            pip install flake8 flake8-bugbear --quiet
                            flake8 ${env.SRC_DIR}/ \\
                                --max-line-length=120 \\
                                --exclude=__pycache__,.git \\
                                --format=default \\
                                2>&1 | tee flake8-report.txt || true
                        """
                        archiveArtifacts 'flake8-report.txt'
                    }
                }

                stage('black') {
                    agent {
                        docker { image env.PYTHON_IMAGE; reuseNode true }
                    }
                    steps {
                        sh """
                            pip install black --quiet
                            black --check --diff ${env.SRC_DIR}/ 2>&1 | tee black-report.txt || true
                        """
                        archiveArtifacts 'black-report.txt'
                    }
                }

                stage('mypy') {
                    agent {
                        docker { image env.PYTHON_IMAGE; reuseNode true }
                    }
                    steps {
                        sh """
                            pip install mypy --quiet
                            mypy ${env.SRC_DIR}/ \\
                                --ignore-missing-imports \\
                                --no-error-summary \\
                                2>&1 | tee mypy-report.txt || true
                        """
                        archiveArtifacts 'mypy-report.txt'
                    }
                }

                stage('isort') {
                    agent {
                        docker { image env.PYTHON_IMAGE; reuseNode true }
                    }
                    steps {
                        sh """
                            pip install isort --quiet
                            isort --check-only --diff ${env.SRC_DIR}/ 2>&1 | tee isort-report.txt || true
                        """
                        archiveArtifacts 'isort-report.txt'
                    }
                }

            } // end parallel lint
        }

        stage('Build Images') {
            agent { label 'docker' }
            steps {
                sh """
                    echo \${DOCKER_CREDS_PSW} | docker login ${env.DOCKER_REGISTRY} \\
                        -u \${DOCKER_CREDS_USR} --password-stdin || true

                    # Build custom service images
                    for svc in api-server code-executor workflows-runner general-mcp; do
                        IMAGE_PATH="compose/docker/\${svc}"
                        if [ -d "\${IMAGE_PATH}" ]; then
                            docker build \\
                                --build-arg BUILDKIT_INLINE_CACHE=1 \\
                                --cache-from ${env.DOCKER_REGISTRY}/aistack-\${svc}:latest \\
                                --tag ${env.DOCKER_REGISTRY}/aistack-\${svc}:${env.IMAGE_TAG} \\
                                --tag ${env.DOCKER_REGISTRY}/aistack-\${svc}:latest \\
                                \${IMAGE_PATH}
                        fi
                    done
                """
            }
        }

        stage('Unit Tests') {
            agent {
                docker {
                    image env.PYTHON_IMAGE
                    reuseNode true
                }
            }
            steps {
                sh """
                    pip install -r requirements.txt --quiet
                    pip install pytest pytest-cov pytest-asyncio httpx --quiet

                    pytest ${env.SRC_DIR}/ \\
                        -v \\
                        --tb=short \\
                        -m "unit or not (functional or regression or smoke or integration)" \\
                        --cov=${env.SRC_DIR}/ \\
                        --cov-report=xml:coverage.xml \\
                        --cov-report=term-missing \\
                        --junitxml=unit-tests.xml \\
                        2>&1 | tee unit-test-output.txt || true
                """
            }
            post {
                always {
                    junit allowEmptyResults: true, testResults: 'unit-tests.xml'
                    archiveArtifacts artifacts: 'coverage.xml', allowEmptyArchive: true
                }
            }
        }

        stage('Integration Tests') {
            agent { label 'docker' }
            stages {

                stage('Start Core Services') {
                    steps {
                        sh """
                            docker compose \\
                                --project-name aistack-test-${env.BUILD_NUMBER} \\
                                --file ${env.COMPOSE_FILE} \\
                                up -d --wait postgres redis api-server
                        """
                        sh 'sleep 8'
                    }
                }

                stage('Smoke Tests') {
                    steps {
                        sh """
                            # API server health
                            curl -sf http://localhost:8000/health && echo 'API: OK'
                            curl -sf http://localhost:8000/docs   -o /dev/null && echo 'OpenAPI docs: OK'
                        """
                    }
                }

                stage('Functional Tests') {
                    agent {
                        docker {
                            image env.PYTHON_IMAGE
                            args  '--network host'
                            reuseNode true
                        }
                    }
                    steps {
                        sh """
                            pip install -r requirements.txt pytest pytest-asyncio httpx --quiet
                            pytest ${env.SRC_DIR}/ \\
                                -v \\
                                -m functional \\
                                --tb=short \\
                                --junitxml=functional-tests.xml \\
                                2>&1 | tee functional-output.txt || true
                        """
                    }
                    post {
                        always {
                            junit allowEmptyResults: true, testResults: 'functional-tests.xml'
                        }
                    }
                }

                stage('Regression Tests') {
                    agent {
                        docker {
                            image env.PYTHON_IMAGE
                            args  '--network host'
                            reuseNode true
                        }
                    }
                    steps {
                        sh """
                            pip install -r requirements.txt pytest pytest-asyncio httpx --quiet
                            pytest ${env.SRC_DIR}/ \\
                                -v \\
                                -m regression \\
                                --tb=short \\
                                --junitxml=regression-tests.xml \\
                                2>&1 | tee regression-output.txt || true
                        """
                    }
                    post {
                        always {
                            junit allowEmptyResults: true, testResults: 'regression-tests.xml'
                        }
                    }
                }

                stage('Tear Down') {
                    steps {
                        sh """
                            docker compose \\
                                --project-name aistack-test-${env.BUILD_NUMBER} \\
                                down --volumes --remove-orphans || true
                        """
                    }
                }

            } // end nested stages
        }

        stage('SonarQube') {
            when { not { expression { params.SKIP_SONAR } } }
            agent { label 'docker' }
            steps {
                sonarScan(
                    projectKey: env.SONAR_KEY,
                    projectName: 'local-aistack Backend',
                    sources: env.SRC_DIR,
                    language: 'python',
                    coverageReport: 'coverage.xml',
                    exclusions: '**/__pycache__/**,**/migrations/**,**/notebooks/**',
                )
            }
        }

        stage('ZAP Scan') {
            when { not { expression { params.SKIP_ZAP } } }
            agent { label 'docker' }
            steps {
                sh """
                    docker compose --project-name aistack-zap-${env.BUILD_NUMBER} \\
                        --file ${env.COMPOSE_FILE} \\
                        up -d --wait postgres redis api-server
                """
                script {
                    try {
                        zapScan(
                            target: 'http://localhost:8000',
                            mode: env.ZAP_SCAN_MODE ?: 'baseline',
                            reportName: 'aistack-backend',
                            network: 'host',
                        )
                    } finally {
                        sh "docker compose --project-name aistack-zap-${env.BUILD_NUMBER} down --volumes || true"
                    }
                }
            }
        }

        stage('Push Images') {
            when { not { expression { params.SKIP_DEPLOY } } }
            agent { label 'docker' }
            steps {
                sh """
                    echo \${DOCKER_CREDS_PSW} | docker login ${env.DOCKER_REGISTRY} \\
                        -u \${DOCKER_CREDS_USR} --password-stdin
                    for svc in api-server code-executor workflows-runner general-mcp; do
                        docker push ${env.DOCKER_REGISTRY}/aistack-\${svc}:${env.IMAGE_TAG} || true
                        docker push ${env.DOCKER_REGISTRY}/aistack-\${svc}:latest || true
                    done
                """
            }
        }

    } // end stages

    post {
        always {
            node('docker') { cleanWs() }
        }
        success { echo "local-aistack backend CI passed" }
        failure { echo "local-aistack backend CI FAILED" }
    }

}
