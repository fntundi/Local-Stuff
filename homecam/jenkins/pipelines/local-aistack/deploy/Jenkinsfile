// ============================================================================
// local-aistack — Deploy Pipeline
// Docker Compose (primary) with optional k8s path
//
// Stages:
//   Input Gate (prod) → Pre-flight → Pull Images → Deploy → Health Check → Tag
// ============================================================================

@Library('home-platform') _

pipeline {

    agent { label 'docker' }

    options {
        ansiColor('xterm')
        timestamps()
        timeout(time: 30, unit: 'MINUTES')
        buildDiscarder(logRotator(numToKeepStr: '30'))
        disableConcurrentBuilds()
    }

    parameters {
        choice(
            name: 'ENVIRONMENT',
            choices: ['dev', 'prod'],
            description: 'Target deploy environment (maps to env/.env.<env>)'
        )
        string(
            name: 'DOCKER_TAG',
            defaultValue: 'latest',
            description: 'Image tag to deploy for custom services'
        )
        choice(
            name: 'STRATEGY',
            choices: ['compose', 'k8s'],
            description: 'Deploy via docker-compose or Kubernetes'
        )
        booleanParam(
            name: 'SERVICES_ONLY',
            defaultValue: false,
            description: 'Only restart/recreate custom services (not third-party images)'
        )
        booleanParam(
            name: 'FORCE_DEPLOY',
            defaultValue: false,
            description: 'Bypass approval gate (dev/staging only)'
        )
    }

    environment {
        APP          = 'local-aistack'
        COMPOSE_BASE = 'compose/docker-compose.yml'
        COMPOSE_PROD = 'compose/docker-compose.prod.yml'
        IMAGE_TAG    = "${params.DOCKER_TAG}"
        KUBE_CONFIG  = credentials('kubeconfig-aistack')
        DOCKER_CREDS = credentials('docker-registry-creds')
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
                script {
                    def globalEnv = readFile('jenkins/pipelines/global.env')
                    def appEnv    = readFile('jenkins/pipelines/local-aistack/local-aistack.env')
                    [globalEnv, appEnv].each { block ->
                        block.readLines().each { line ->
                            if (line && !line.startsWith('#') && line.contains('=')) {
                                def (k, v) = line.split('=', 2)
                                env[k.trim()] = v.trim()
                            }
                        }
                    }

                    env.ENV_FILE      = params.ENVIRONMENT == 'prod' ? env.ENV_FILE_PROD : env.ENV_FILE_DEV
                    env.COMPOSE_FILES = params.ENVIRONMENT == 'prod' ?
                        "-f ${env.COMPOSE_BASE} -f ${env.COMPOSE_PROD}" :
                        "-f ${env.COMPOSE_BASE}"
                }
            }
        }

        stage('Approval Gate') {
            when {
                allOf {
                    expression { params.ENVIRONMENT == 'prod' }
                    not { expression { params.FORCE_DEPLOY } }
                }
            }
            steps {
                input(
                    message: "Deploy local-aistack tag '${env.IMAGE_TAG}' to PRODUCTION?",
                    ok: 'Deploy',
                    submitter: 'admin,deploy-approvers'
                )
            }
        }

        stage('Pre-flight') {
            steps {
                sh """
                    echo \${DOCKER_CREDS_PSW} | docker login ${env.DOCKER_REGISTRY} \\
                        -u \${DOCKER_CREDS_USR} --password-stdin

                    # Verify custom images exist
                    for svc in api-server code-executor workflows-runner general-mcp; do
                        docker manifest inspect ${env.DOCKER_REGISTRY}/aistack-\${svc}:${env.IMAGE_TAG} \\
                            && echo "\${svc}: OK" || echo "\${svc}: NOT FOUND (will use existing)"
                    done

                    # Confirm env file exists
                    [ -f ${env.ENV_FILE} ] || { echo "ERROR: env file not found: ${env.ENV_FILE}"; exit 1; }
                """
            }
        }

        stage('Deploy (Compose)') {
            when { expression { params.STRATEGY == 'compose' } }
            steps {
                sh """
                    export DOCKER_TAG=${env.IMAGE_TAG}

                    # Pull all images (non-blocking on failure for custom ones)
                    docker compose \\
                        --project-name ai-platform \\
                        ${env.COMPOSE_FILES} \\
                        --env-file ${env.ENV_FILE} \\
                        pull --ignore-pull-failures

                    # Deploy
                    docker compose \\
                        --project-name ai-platform \\
                        ${env.COMPOSE_FILES} \\
                        --env-file ${env.ENV_FILE} \\
                        up -d --remove-orphans

                    # Show running containers
                    docker compose \\
                        --project-name ai-platform \\
                        ${env.COMPOSE_FILES} \\
                        --env-file ${env.ENV_FILE} \\
                        ps
                """
            }
        }

        stage('Deploy (k8s)') {
            when { expression { params.STRATEGY == 'k8s' } }
            steps {
                withEnv(["KUBECONFIG=${env.KUBE_CONFIG}"]) {
                    deployApp(
                        app: 'local-aistack',
                        environment: params.ENVIRONMENT,
                        strategy: 'k8s',
                        namespace: env.K8S_NAMESPACE ?: 'ai-platform',
                        k8sDir: 'k8s/base',
                        imageTag: env.IMAGE_TAG,
                        kubeconfigCredId: 'kubeconfig-aistack',
                    )
                }
            }
        }

        stage('Post-Deploy Health') {
            steps {
                sh '''
                    sleep 20  # allow services to initialise

                    check() {
                        local name=$1 url=$2
                        STATUS=$(curl -s -o /dev/null -w '%{http_code}' --max-time 15 "$url" || echo '000')
                        if echo "$STATUS" | grep -qE '^(2|3)'; then
                            echo "  ✓ $name [$STATUS]"
                        else
                            echo "  ⚠ $name [$STATUS]"
                        fi
                    }

                    echo '=== Post-Deploy Health Check ==='
                    check 'API Server'  'http://localhost:8000/health'
                    check 'OpenWebUI'   'http://localhost:3000'
                    check 'JupyterLab'  'http://localhost:8888'
                    check 'MLflow'      'http://localhost:5000'
                '''
            }
        }

    } // end stages

    post {
        success {
            echo "local-aistack deployed to ${params.ENVIRONMENT} — tag: ${env.IMAGE_TAG}"
        }
        failure {
            echo "local-aistack deploy FAILED — manual rollback may be needed"
        }
        always {
            cleanWs()
        }
    }

}
