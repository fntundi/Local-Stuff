// ============================================================================
// Sentinel-Home — Deploy Pipeline  (Skeleton)
//
// Pre-wired with approval gate and rollback. Fill in TODO sections once
// the deployment strategy (compose vs k8s) and URLs are defined.
// ============================================================================

@Library('home-platform') _

pipeline {

    agent { label 'docker' }

    options {
        ansiColor('xterm')
        timestamps()
        timeout(time: 30, unit: 'MINUTES')
        buildDiscarder(logRotator(numToKeepStr: '30'))
        disableConcurrentBuilds()
    }

    parameters {
        choice(
            name: 'ENVIRONMENT',
            choices: ['dev', 'staging', 'prod'],
            description: 'Target environment'
        )
        string(
            name: 'DOCKER_TAG',
            defaultValue: 'latest',
            description: 'Image tag to deploy'
        )
        choice(
            name: 'STRATEGY',
            choices: ['compose', 'k8s'],
            description: 'Deployment strategy'
        )
        booleanParam(
            name: 'FORCE_DEPLOY',
            defaultValue: false,
            description: 'Bypass approval gate'
        )
    }

    environment {
        APP          = 'sentinel-home'
        IMAGE_TAG    = "${params.DOCKER_TAG}"
        KUBE_CONFIG  = credentials('kubeconfig-sentinel')
        DOCKER_CREDS = credentials('docker-registry-creds')
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
                script {
                    def globalEnv = readFile('jenkins/pipelines/global.env')
                    def appEnv    = readFile('jenkins/pipelines/sentinel-home/sentinel-home.env')
                    [globalEnv, appEnv].each { block ->
                        block.readLines().each { line ->
                            if (line && !line.startsWith('#') && line.contains('=')) {
                                def (k, v) = line.split('=', 2)
                                env[k.trim()] = v.trim()
                            }
                        }
                    }
                }
            }
        }

        stage('Approval Gate') {
            when {
                allOf {
                    expression { params.ENVIRONMENT == 'prod' }
                    not { expression { params.FORCE_DEPLOY } }
                }
            }
            steps {
                input(
                    message: "Deploy Sentinel-Home '${env.IMAGE_TAG}' to PRODUCTION?",
                    ok: 'Deploy',
                    submitter: 'admin,deploy-approvers'
                )
            }
        }

        stage('Deploy') {
            steps {
                script {
                    if (params.STRATEGY == 'compose') {
                        // TODO: update COMPOSE_FILE and ENV_FILE paths
                        echo "TODO: define docker-compose.yml for Sentinel-Home, then uncomment below"
                        // sh """
                        //     export DOCKER_TAG=${env.IMAGE_TAG}
                        //     docker compose --project-name sentinel-home \\
                        //         --file docker-compose.yml \\
                        //         --env-file env/.env.${params.ENVIRONMENT} \\
                        //         up -d --remove-orphans
                        // """
                    } else {
                        // TODO: update k8s directory
                        echo "TODO: define k8s manifests for Sentinel-Home, then enable deployApp call"
                        // withEnv(["KUBECONFIG=${env.KUBE_CONFIG}"]) {
                        //     deployApp(
                        //         app: 'sentinel-home',
                        //         environment: params.ENVIRONMENT,
                        //         strategy: 'k8s',
                        //         namespace: env.K8S_NAMESPACE,
                        //         k8sDir: env.K8S_DIR,
                        //         imageTag: env.IMAGE_TAG,
                        //         kubeconfigCredId: 'kubeconfig-sentinel',
                        //     )
                        // }
                    }
                }
            }
        }

        stage('Post-Deploy Smoke') {
            steps {
                // TODO: add health check URL once service is defined
                echo "TODO: add post-deploy smoke tests once Sentinel-Home is running"
            }
        }

    } // end stages

    post {
        success {
            echo "Sentinel-Home deployed to ${params.ENVIRONMENT} — tag: ${env.IMAGE_TAG}"
        }
        failure {
            echo "Sentinel-Home deploy FAILED — manual rollback may be needed"
        }
        always {
            cleanWs()
        }
    }

}
