// ============================================================================
// Sentinel-Home — Backend CI Pipeline  (Skeleton)
//
// Pre-wired for multi-language support. Set BACKEND_LANG in sentinel-home.env
// and fill in TODO sections once the stack is defined.
//
// Stages:
//   Checkout → Lint → Build → Unit Tests → Smoke →
//   Functional → Regression → SonarQube → ZAP → Push
// ============================================================================

@Library('home-platform') _

pipeline {

    agent none

    options {
        ansiColor('xterm')
        timestamps()
        timeout(time: 45, unit: 'MINUTES')
        buildDiscarder(logRotator(numToKeepStr: '50', daysToKeepStr: '30'))
        disableConcurrentBuilds()
    }

    parameters {
        choice(
            name: 'ENVIRONMENT',
            choices: ['dev', 'staging', 'prod'],
            description: 'Target environment'
        )
        booleanParam(name: 'SKIP_SONAR',  defaultValue: false, description: 'Skip SonarQube')
        booleanParam(name: 'SKIP_ZAP',    defaultValue: false, description: 'Skip ZAP DAST')
        booleanParam(name: 'SKIP_DEPLOY', defaultValue: true,  description: 'Skip image push')
        string(name: 'DOCKER_TAG', defaultValue: '', description: 'Override image tag')
    )

    environment {
        APP           = 'sentinel-home'
        COMPONENT     = 'backend'
        // TODO: choose build image based on BACKEND_LANG
        BUILD_IMAGE   = 'python:3.11-slim'
        BACKEND_DIR   = 'backend'
        IMAGE_NAME    = "${env.DOCKER_REGISTRY ?: 'localhost:5000'}/sentinel-home-backend"
        SONAR_KEY     = 'home-platform.sentinel-home.backend'
        SONAR_TOKEN   = credentials('sonarqube-token')
        DOCKER_CREDS  = credentials('docker-registry-creds')
    }

    stages {

        stage('Checkout') {
            agent { label 'docker' }
            steps {
                checkout scm
                script {
                    env.GIT_SHORT = sh(returnStdout: true, script: 'git rev-parse --short HEAD').trim()
                    env.IMAGE_TAG = params.DOCKER_TAG ?: env.GIT_SHORT

                    def globalEnv = readFile('jenkins/pipelines/global.env')
                    def appEnv    = readFile('jenkins/pipelines/sentinel-home/sentinel-home.env')
                    [globalEnv, appEnv].each { block ->
                        block.readLines().each { line ->
                            if (line && !line.startsWith('#') && line.contains('=')) {
                                def (k, v) = line.split('=', 2)
                                env[k.trim()] = v.trim()
                            }
                        }
                    }
                }
            }
        }

        stage('Lint') {
            agent {
                docker { image env.BUILD_IMAGE; reuseNode true }
            }
            steps {
                dir(env.BACKEND_DIR) {
                    // TODO: add language-appropriate lint commands
                    echo "TODO: add lint commands (flake8 / go vet / eslint) for ${env.BACKEND_LANG ?: 'unknown'} backend"
                }
            }
        }

        stage('Build') {
            agent {
                docker { image env.BUILD_IMAGE; reuseNode true }
            }
            steps {
                dir(env.BACKEND_DIR) {
                    // TODO: add build command
                    echo "TODO: add build command"
                }
                // TODO: uncomment once Dockerfile exists
                // sh "docker build --tag ${env.IMAGE_NAME}:${env.IMAGE_TAG} ${env.BACKEND_DIR}"
                echo "TODO: build Docker image — add Dockerfile to ${env.BACKEND_DIR}/"
            }
        }

        stage('Unit Tests') {
            agent {
                docker { image env.BUILD_IMAGE; reuseNode true }
            }
            steps {
                dir(env.BACKEND_DIR) {
                    // TODO: add unit test command
                    echo "TODO: add unit tests (pytest / go test / jest)"
                }
            }
        }

        stage('Integration Tests') {
            agent { label 'docker' }
            stages {

                stage('Start Test Stack') {
                    steps {
                        // TODO: define docker-compose.yml
                        echo "TODO: define docker-compose.yml for Sentinel-Home"
                    }
                }

                stage('Smoke Tests') {
                    steps {
                        // TODO: add health check URL
                        echo "TODO: add smoke test health check once backend URL is known"
                    }
                }

                stage('Functional Tests') {
                    steps {
                        echo "TODO: add functional tests (mark with @pytest.mark.functional or @functional)"
                    }
                }

                stage('Regression Tests') {
                    steps {
                        echo "TODO: add regression tests (mark with @pytest.mark.regression or @regression)"
                    }
                }

                stage('Tear Down') {
                    steps {
                        sh """
                            docker compose --project-name sentinel-be-test-${env.BUILD_NUMBER} \\
                                down --volumes --remove-orphans || true
                        """
                    }
                }

            }
        }

        stage('SonarQube') {
            when { not { expression { params.SKIP_SONAR } } }
            agent { label 'docker' }
            steps {
                // TODO: update language when stack is defined
                sonarScan(
                    projectKey: env.SONAR_KEY,
                    projectName: 'Sentinel-Home Backend',
                    sources: env.BACKEND_DIR,
                    language: env.BACKEND_LANG ?: 'generic',
                    exclusions: '**/vendor/**,**/__pycache__/**',
                )
            }
        }

        stage('ZAP Scan') {
            when { not { expression { params.SKIP_ZAP } } }
            agent { label 'docker' }
            steps {
                echo "TODO: start backend service before ZAP scan"
                zapScan(
                    target: env.BACKEND_URL_DEV ?: 'http://sentinel-home-backend:8000',
                    mode: env.ZAP_SCAN_MODE ?: 'baseline',
                    reportName: 'sentinel-home-backend',
                    network: 'host',
                )
            }
        }

        stage('Push Image') {
            when { not { expression { params.SKIP_DEPLOY } } }
            agent { label 'docker' }
            steps {
                echo "TODO: push image once build step is configured"
            }
        }

    } // end stages

    post {
        always {
            node('docker') { cleanWs() }
        }
        success { echo "Sentinel-Home backend CI passed" }
        failure { echo "Sentinel-Home backend CI FAILED" }
    }

}
