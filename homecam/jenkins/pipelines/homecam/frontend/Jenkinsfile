// ============================================================================
// HomeCam — Frontend CI Pipeline
// React 19 (craco) | shadcn/ui | Tailwind CSS
//
// Stages:
//   Checkout → Install → Lint → Build → Unit Tests → Smoke →
//   Functional → Regression → SonarQube → ZAP → 508 Accessibility
// ============================================================================

@Library('home-platform') _

pipeline {

    agent none

    options {
        ansiColor('xterm')
        timestamps()
        timeout(time: 60, unit: 'MINUTES')
        buildDiscarder(logRotator(numToKeepStr: '50', daysToKeepStr: '30'))
        disableConcurrentBuilds()
    }

    parameters {
        choice(
            name: 'ENVIRONMENT',
            choices: ['dev', 'staging', 'prod'],
            description: 'Target environment for runtime URL resolution'
        )
        booleanParam(name: 'SKIP_SONAR',  defaultValue: false, description: 'Skip SonarQube scan')
        booleanParam(name: 'SKIP_ZAP',    defaultValue: false, description: 'Skip OWASP ZAP scan')
        booleanParam(name: 'SKIP_508',    defaultValue: false, description: 'Skip 508 accessibility tests')
        booleanParam(name: 'SKIP_DEPLOY', defaultValue: true,  description: 'Skip deploy after tests pass')
        string(
            name: 'DOCKER_TAG',
            defaultValue: '',
            description: 'Override image tag (default: short commit SHA)'
        )
        string(
            name: 'ZAP_TARGET_OVERRIDE',
            defaultValue: '',
            description: 'Override ZAP target URL (leave blank to use env-file default)'
        )
    }

    environment {
        APP           = 'homecam'
        COMPONENT     = 'frontend'
        NODE_IMAGE    = 'node:20-alpine'
        FRONTEND_DIR  = 'frontend'
        IMAGE_NAME    = "${env.DOCKER_REGISTRY ?: 'localhost:5000'}/homecam-frontend"
        SONAR_KEY     = 'home-platform.homecam.frontend'
        SONAR_TOKEN   = credentials('sonarqube-token')
        DOCKER_CREDS  = credentials('docker-registry-creds')
    }

    stages {

        // ----------------------------------------------------------------
        stage('Checkout') {
        // ----------------------------------------------------------------
            agent { label 'docker' }
            steps {
                checkout scm
                script {
                    env.GIT_SHORT = sh(returnStdout: true, script: 'git rev-parse --short HEAD').trim()
                    env.IMAGE_TAG = params.DOCKER_TAG ?: env.GIT_SHORT
                    echo "Building tag: ${env.IMAGE_TAG}"

                    // Load env files into environment
                    def globalEnv = readFile('jenkins/pipelines/global.env')
                    def appEnv    = readFile('jenkins/pipelines/homecam/homecam.env')
                    [globalEnv, appEnv].each { block ->
                        block.readLines().each { line ->
                            if (line && !line.startsWith('#') && line.contains('=')) {
                                def (k, v) = line.split('=', 2)
                                env[k.trim()] = v.trim()
                            }
                        }
                    }

                    // Resolve target URL based on environment
                    env.FRONTEND_TARGET_URL = params.ZAP_TARGET_OVERRIDE ?:
                        (params.ENVIRONMENT == 'prod'    ? env.FRONTEND_URL_PROD :
                         params.ENVIRONMENT == 'staging' ? env.FRONTEND_URL_STAGING :
                         env.FRONTEND_URL_DEV)
                }
            }
        }

        // ----------------------------------------------------------------
        stage('Install Dependencies') {
        // ----------------------------------------------------------------
            agent {
                docker {
                    image env.NODE_IMAGE
                    args  "--network ${env.TRAEFIK_NETWORK ?: 'home-net'} -v ${env.BUILD_CACHE_DIR ?: '/tmp/buildcache'}:/usr/local/share/.cache"
                    reuseNode true
                }
            }
            steps {
                dir(env.FRONTEND_DIR) {
                    sh 'yarn install --frozen-lockfile'
                }
            }
        }

        // ----------------------------------------------------------------
        stage('Lint') {
        // ----------------------------------------------------------------
            agent {
                docker { image env.NODE_IMAGE; reuseNode true }
            }
            steps {
                dir(env.FRONTEND_DIR) {
                    sh 'yarn lint --max-warnings=0 2>&1 | tee lint-report.txt'
                }
            }
            post {
                always {
                    archiveArtifacts artifacts: "${env.FRONTEND_DIR}/lint-report.txt", allowEmptyArchive: true
                }
            }
        }

        // ----------------------------------------------------------------
        stage('Build') {
        // ----------------------------------------------------------------
            agent {
                docker { image env.NODE_IMAGE; reuseNode true }
            }
            steps {
                dir(env.FRONTEND_DIR) {
                    sh 'yarn build'
                }
                sh """
                    docker build \\
                        --build-arg BUILDKIT_INLINE_CACHE=1 \\
                        --cache-from ${env.IMAGE_NAME}:latest \\
                        --tag ${env.IMAGE_NAME}:${env.IMAGE_TAG} \\
                        --tag ${env.IMAGE_NAME}:latest \\
                        ${env.FRONTEND_DIR}
                """
            }
        }

        // ----------------------------------------------------------------
        stage('Unit Tests') {
        // ----------------------------------------------------------------
            agent {
                docker { image env.NODE_IMAGE; reuseNode true }
            }
            steps {
                dir(env.FRONTEND_DIR) {
                    sh '''
                        CI=true yarn test \
                            --watchAll=false \
                            --coverage \
                            --coverageReporters=lcov,text \
                            --passWithNoTests \
                            2>&1 | tee unit-test-report.txt
                    '''
                }
            }
            post {
                always {
                    publishHTML(target: [
                        allowMissing: true,
                        reportDir: "${env.FRONTEND_DIR}/coverage/lcov-report",
                        reportFiles: 'index.html',
                        reportName: 'Frontend Coverage',
                    ])
                    archiveArtifacts artifacts: "${env.FRONTEND_DIR}/coverage/**", allowEmptyArchive: true
                }
            }
        }

        // ----------------------------------------------------------------
        stage('Integration Tests') {
        // ----------------------------------------------------------------
            // Spin up frontend + backend via compose, run smoke/functional/regression
            agent { label 'docker' }
            stages {

                stage('Start Test Stack') {
                    steps {
                        sh """
                            docker compose \\
                                --project-name homecam-test-${env.BUILD_NUMBER} \\
                                --file docker-compose.yml \\
                                up -d --build --wait
                        """
                        sh 'sleep 5'  // brief settle time after --wait
                    }
                }

                stage('Smoke Tests') {
                    steps {
                        sh """
                            # Health check — frontend serves 200
                            curl -sf http://localhost:3000/ -o /dev/null && echo 'Frontend: OK'

                            # API reachable through frontend proxy
                            curl -sf http://localhost:3000/api/auth/me \
                                -H 'Authorization: Bearer invalid' \
                                -o /dev/null -w '%{http_code}' | grep -E '401|403' && echo 'API auth gate: OK'
                        """
                    }
                }

                stage('Functional Tests') {
                    agent {
                        docker {
                            image env.PLAYWRIGHT_IMAGE ?: 'mcr.microsoft.com/playwright:v1.44.0-jammy'
                            args  "--network host"
                            reuseNode true
                        }
                    }
                    steps {
                        dir('tests/e2e') {
                            sh '''
                                npm ci --prefer-offline 2>/dev/null || true
                                BASE_URL=http://localhost:3000 \
                                    npx playwright test \
                                        --project=chromium \
                                        --grep @functional \
                                        --reporter=html,junit \
                                        2>&1 | tee functional-results.txt
                            '''
                        }
                    }
                    post {
                        always {
                            junit allowEmptyResults: true, testResults: 'tests/e2e/test-results/**/*.xml'
                            publishHTML(target: [
                                reportDir: 'tests/e2e/playwright-report',
                                reportFiles: 'index.html',
                                reportName: 'Functional Tests — Frontend',
                            ])
                        }
                    }
                }

                stage('Regression Tests') {
                    agent {
                        docker {
                            image env.PLAYWRIGHT_IMAGE ?: 'mcr.microsoft.com/playwright:v1.44.0-jammy'
                            args  "--network host"
                            reuseNode true
                        }
                    }
                    steps {
                        dir('tests/e2e') {
                            sh '''
                                BASE_URL=http://localhost:3000 \
                                    npx playwright test \
                                        --project=chromium \
                                        --grep @regression \
                                        --reporter=html,junit \
                                        2>&1 | tee regression-results.txt
                            '''
                        }
                    }
                    post {
                        always {
                            junit allowEmptyResults: true, testResults: 'tests/e2e/test-results/**/*.xml'
                            publishHTML(target: [
                                reportDir: 'tests/e2e/playwright-report',
                                reportFiles: 'index.html',
                                reportName: 'Regression Tests — Frontend',
                            ])
                        }
                    }
                }

                stage('Tear Down Test Stack') {
                    steps {
                        sh """
                            docker compose \\
                                --project-name homecam-test-${env.BUILD_NUMBER} \\
                                down --volumes --remove-orphans || true
                        """
                    }
                }

            } // end nested stages
        } // end Integration Tests

        // ----------------------------------------------------------------
        stage('SonarQube') {
        // ----------------------------------------------------------------
            when { not { expression { params.SKIP_SONAR } } }
            agent { label 'docker' }
            steps {
                sonarScan(
                    projectKey: env.SONAR_KEY,
                    projectName: 'HomeCam Frontend',
                    sources: env.FRONTEND_DIR,
                    language: 'js',
                    coverageReport: "${env.FRONTEND_DIR}/coverage/lcov.info",
                    exclusions: '**/node_modules/**,**/build/**,**/*.test.js,**/*.spec.js',
                )
            }
        }

        // ----------------------------------------------------------------
        stage('ZAP Scan') {
        // ----------------------------------------------------------------
            when { not { expression { params.SKIP_ZAP } } }
            agent { label 'docker' }
            steps {
                script {
                    // Bring up just frontend for ZAP scan
                    sh """
                        docker compose --project-name homecam-zap-${env.BUILD_NUMBER} \\
                            --file docker-compose.yml up -d --wait
                    """
                    try {
                        zapScan(
                            target: 'http://localhost:3000',
                            mode: env.ZAP_SCAN_MODE ?: 'baseline',
                            reportName: 'homecam-frontend',
                            network: 'host',
                        )
                    } finally {
                        sh "docker compose --project-name homecam-zap-${env.BUILD_NUMBER} down --volumes || true"
                    }
                }
            }
        }

        // ----------------------------------------------------------------
        stage('508 Accessibility') {
        // ----------------------------------------------------------------
            when { not { expression { params.SKIP_508 } } }
            agent { label 'docker' }
            steps {
                sh """
                    docker compose --project-name homecam-508-${env.BUILD_NUMBER} \\
                        --file docker-compose.yml up -d --wait
                """
                playwright508(
                    dir: env.FRONTEND_DIR,
                    baseUrl: 'http://localhost:3000',
                    wcagLevel: env.WCAG_LEVEL ?: 'wcag21aa',
                    failOnViolation: false,
                )
            }
            post {
                always {
                    sh "docker compose --project-name homecam-508-${env.BUILD_NUMBER} down --volumes || true"
                }
            }
        }

        // ----------------------------------------------------------------
        stage('Push Image') {
        // ----------------------------------------------------------------
            when { not { expression { params.SKIP_DEPLOY } } }
            agent { label 'docker' }
            steps {
                sh """
                    echo \${DOCKER_CREDS_PSW} | docker login ${env.DOCKER_REGISTRY} \\
                        -u \${DOCKER_CREDS_USR} --password-stdin
                    docker push ${env.IMAGE_NAME}:${env.IMAGE_TAG}
                    docker push ${env.IMAGE_NAME}:latest
                """
            }
        }

    } // end stages

    post {
        always {
            node('docker') {
                cleanWs()
            }
        }
        success {
            echo "Frontend CI passed — image: ${env.IMAGE_NAME}:${env.IMAGE_TAG}"
        }
        failure {
            echo "Frontend CI FAILED — review stage logs and published reports"
        }
    }

} // end pipeline
