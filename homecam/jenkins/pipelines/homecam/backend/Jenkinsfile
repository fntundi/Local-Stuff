// ============================================================================
// HomeCam — Backend CI Pipeline
// Go 1.21 | Gin | MongoDB Motor
//
// Stages:
//   Checkout → go vet/staticcheck → Build → Unit Tests → Smoke →
//   Functional → Regression → SonarQube → ZAP
// ============================================================================

@Library('home-platform') _

pipeline {

    agent none

    options {
        ansiColor('xterm')
        timestamps()
        timeout(time: 45, unit: 'MINUTES')
        buildDiscarder(logRotator(numToKeepStr: '50', daysToKeepStr: '30'))
        disableConcurrentBuilds()
    }

    parameters {
        choice(
            name: 'ENVIRONMENT',
            choices: ['dev', 'staging', 'prod'],
            description: 'Target environment for URL resolution'
        )
        booleanParam(name: 'SKIP_SONAR',  defaultValue: false, description: 'Skip SonarQube scan')
        booleanParam(name: 'SKIP_ZAP',    defaultValue: false, description: 'Skip OWASP ZAP scan')
        booleanParam(name: 'SKIP_DEPLOY', defaultValue: true,  description: 'Skip image push after tests')
        string(
            name: 'DOCKER_TAG',
            defaultValue: '',
            description: 'Override image tag (default: short commit SHA)'
        )
    )

    environment {
        APP           = 'homecam'
        COMPONENT     = 'backend'
        GO_IMAGE      = 'golang:1.21-alpine'
        BACKEND_DIR   = 'backend'
        IMAGE_NAME    = "${env.DOCKER_REGISTRY ?: 'localhost:5000'}/homecam-backend"
        SONAR_KEY     = 'home-platform.homecam.backend'
        SONAR_TOKEN   = credentials('sonarqube-token')
        DOCKER_CREDS  = credentials('docker-registry-creds')
        CGO_ENABLED   = '0'
        GOFLAGS       = '-mod=mod'
    }

    stages {

        // ----------------------------------------------------------------
        stage('Checkout') {
        // ----------------------------------------------------------------
            agent { label 'docker' }
            steps {
                checkout scm
                script {
                    env.GIT_SHORT = sh(returnStdout: true, script: 'git rev-parse --short HEAD').trim()
                    env.IMAGE_TAG = params.DOCKER_TAG ?: env.GIT_SHORT

                    def globalEnv = readFile('jenkins/pipelines/global.env')
                    def appEnv    = readFile('jenkins/pipelines/homecam/homecam.env')
                    [globalEnv, appEnv].each { block ->
                        block.readLines().each { line ->
                            if (line && !line.startsWith('#') && line.contains('=')) {
                                def (k, v) = line.split('=', 2)
                                env[k.trim()] = v.trim()
                            }
                        }
                    }

                    env.BACKEND_TARGET_URL = params.ENVIRONMENT == 'prod'    ? env.BACKEND_URL_PROD :
                                             params.ENVIRONMENT == 'staging' ? env.BACKEND_URL_STAGING :
                                             env.BACKEND_URL_DEV
                }
            }
        }

        // ----------------------------------------------------------------
        stage('Lint & Vet') {
        // ----------------------------------------------------------------
            agent {
                docker {
                    image env.GO_IMAGE
                    args  '-v go-mod-cache:/root/go/pkg/mod'
                    reuseNode true
                }
            }
            steps {
                dir(env.BACKEND_DIR) {
                    sh '''
                        go mod tidy
                        go vet ./... 2>&1 | tee go-vet-report.txt

                        # Install and run staticcheck if available
                        go install honnef.co/go/tools/cmd/staticcheck@latest 2>/dev/null || true
                        staticcheck ./... 2>&1 | tee staticcheck-report.txt || true
                    '''
                }
            }
            post {
                always {
                    archiveArtifacts artifacts: "${env.BACKEND_DIR}/*-report.txt", allowEmptyArchive: true
                }
            }
        }

        // ----------------------------------------------------------------
        stage('Build') {
        // ----------------------------------------------------------------
            parallel {
                stage('Compile') {
                    agent {
                        docker {
                            image env.GO_IMAGE
                            args  '-v go-mod-cache:/root/go/pkg/mod'
                            reuseNode true
                        }
                    }
                    steps {
                        dir(env.BACKEND_DIR) {
                            sh 'go build -v ./cmd/api/...'
                        }
                    }
                }

                stage('Docker Image') {
                    agent { label 'docker' }
                    steps {
                        sh """
                            docker build \\
                                --build-arg BUILDKIT_INLINE_CACHE=1 \\
                                --cache-from ${env.IMAGE_NAME}:latest \\
                                --tag ${env.IMAGE_NAME}:${env.IMAGE_TAG} \\
                                --tag ${env.IMAGE_NAME}:latest \\
                                ${env.BACKEND_DIR}
                        """
                    }
                }
            }
        }

        // ----------------------------------------------------------------
        stage('Unit Tests') {
        // ----------------------------------------------------------------
            agent {
                docker {
                    image env.GO_IMAGE
                    args  '-v go-mod-cache:/root/go/pkg/mod'
                    reuseNode true
                }
            }
            steps {
                dir(env.BACKEND_DIR) {
                    sh '''
                        go test ./... \
                            -v \
                            -race \
                            -coverprofile=coverage.out \
                            -covermode=atomic \
                            2>&1 | tee unit-test-output.txt

                        go tool cover -func=coverage.out | tee coverage-summary.txt

                        # Convert to JUnit XML for Jenkins
                        go install github.com/jstemmer/go-junit-report/v2@latest 2>/dev/null || true
                        go-junit-report -set-exit-code < unit-test-output.txt > unit-tests.xml || true
                    '''
                }
            }
            post {
                always {
                    junit allowEmptyResults: true, testResults: "${env.BACKEND_DIR}/unit-tests.xml"
                    archiveArtifacts artifacts: "${env.BACKEND_DIR}/coverage.*", allowEmptyArchive: true
                }
            }
        }

        // ----------------------------------------------------------------
        stage('Integration Tests') {
        // ----------------------------------------------------------------
            agent { label 'docker' }
            stages {

                stage('Start Test Stack') {
                    steps {
                        sh """
                            docker compose \\
                                --project-name homecam-be-test-${env.BUILD_NUMBER} \\
                                --file docker-compose.yml \\
                                up -d --build --wait mongodb backend
                        """
                        sh 'sleep 5'
                    }
                }

                stage('Smoke Tests') {
                    steps {
                        sh """
                            # Health endpoint
                            curl -sf http://localhost:8001/api/health && echo 'Health: OK'

                            # Auth endpoint responds correctly to bad credentials
                            STATUS=\$(curl -s -o /dev/null -w '%{http_code}' \\
                                -X POST http://localhost:8001/api/auth/login \\
                                -H 'Content-Type: application/json' \\
                                -d '{"username":"notexist","password":"wrong"}')
                            echo "Login with bad creds: HTTP \${STATUS}"
                            [ "\${STATUS}" = "401" ] || [ "\${STATUS}" = "400" ]
                        """
                    }
                }

                stage('Functional Tests') {
                    agent {
                        docker {
                            image 'python:3.11-slim'
                            args  '--network host'
                            reuseNode true
                        }
                    }
                    steps {
                        sh '''
                            pip install pytest requests --quiet
                            pytest tests/ \
                                -v \
                                -m "functional" \
                                --tb=short \
                                --junitxml=functional-results.xml \
                                -k "not slow" \
                                2>&1 | tee functional-output.txt || true
                        '''
                    }
                    post {
                        always {
                            junit allowEmptyResults: true, testResults: 'functional-results.xml'
                        }
                    }
                }

                stage('Regression Tests') {
                    agent {
                        docker {
                            image 'python:3.11-slim'
                            args  '--network host'
                            reuseNode true
                        }
                    }
                    steps {
                        sh '''
                            pip install pytest requests --quiet
                            pytest tests/ \
                                -v \
                                -m "regression" \
                                --tb=short \
                                --junitxml=regression-results.xml \
                                2>&1 | tee regression-output.txt || true
                        '''
                    }
                    post {
                        always {
                            junit allowEmptyResults: true, testResults: 'regression-results.xml'
                        }
                    }
                }

                stage('Tear Down Test Stack') {
                    steps {
                        sh """
                            docker compose \\
                                --project-name homecam-be-test-${env.BUILD_NUMBER} \\
                                down --volumes --remove-orphans || true
                        """
                    }
                }

            } // end nested stages
        }

        // ----------------------------------------------------------------
        stage('SonarQube') {
        // ----------------------------------------------------------------
            when { not { expression { params.SKIP_SONAR } } }
            agent { label 'docker' }
            steps {
                sonarScan(
                    projectKey: env.SONAR_KEY,
                    projectName: 'HomeCam Backend',
                    sources: env.BACKEND_DIR,
                    language: 'go',
                    coverageReport: "${env.BACKEND_DIR}/coverage.out",
                    exclusions: '**/vendor/**,**/*_test.go',
                )
            }
        }

        // ----------------------------------------------------------------
        stage('ZAP Scan') {
        // ----------------------------------------------------------------
            when { not { expression { params.SKIP_ZAP } } }
            agent { label 'docker' }
            steps {
                sh """
                    docker compose --project-name homecam-be-zap-${env.BUILD_NUMBER} \\
                        --file docker-compose.yml up -d --wait mongodb backend
                """
                script {
                    try {
                        zapScan(
                            target: 'http://localhost:8001/api',
                            mode: env.ZAP_SCAN_MODE ?: 'baseline',
                            reportName: 'homecam-backend',
                            network: 'host',
                        )
                    } finally {
                        sh "docker compose --project-name homecam-be-zap-${env.BUILD_NUMBER} down --volumes || true"
                    }
                }
            }
        }

        // ----------------------------------------------------------------
        stage('Push Image') {
        // ----------------------------------------------------------------
            when { not { expression { params.SKIP_DEPLOY } } }
            agent { label 'docker' }
            steps {
                sh """
                    echo \${DOCKER_CREDS_PSW} | docker login ${env.DOCKER_REGISTRY} \\
                        -u \${DOCKER_CREDS_USR} --password-stdin
                    docker push ${env.IMAGE_NAME}:${env.IMAGE_TAG}
                    docker push ${env.IMAGE_NAME}:latest
                """
            }
        }

    } // end stages

    post {
        always {
            node('docker') {
                cleanWs()
            }
        }
        success { echo "Backend CI passed — ${env.IMAGE_NAME}:${env.IMAGE_TAG}" }
        failure { echo "Backend CI FAILED — review stage logs above" }
    }

}
